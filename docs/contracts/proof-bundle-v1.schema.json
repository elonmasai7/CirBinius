{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cirbinius.dev/schemas/proof-bundle-v1.schema.json",
  "title": "CirBinius Proof Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "toolchain_version",
    "bundle_hash",
    "backend",
    "status",
    "proof_generated",
    "precheck_bundle_path",
    "precheck_bundle_hash",
    "backend_capabilities_manifest_path",
    "backend_capabilities_manifest_hash",
    "proof_hash",
    "proof_artifact_path",
    "public_inputs_hash",
    "verifier_key_fingerprint",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "proof-bundle/v1"
    },
    "toolchain_version": {
      "type": "string",
      "minLength": 1
    },
    "bundle_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "backend": {
      "type": "string",
      "const": "binius64"
    },
    "status": {
      "type": "string",
      "enum": [
        "precheck-only",
        "proof-generated"
      ]
    },
    "proof_generated": {
      "type": "boolean"
    },
    "precheck_bundle_path": {
      "type": "string",
      "minLength": 1
    },
    "precheck_bundle_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "backend_capabilities_manifest_path": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "backend_capabilities_manifest_hash": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      ]
    },
    "proof_hash": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      ]
    },
    "proof_artifact_path": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "public_inputs_hash": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      ]
    },
    "verifier_key_fingerprint": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
